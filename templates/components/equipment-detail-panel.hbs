<aside class="hm-detail-panel" data-equipment-detail-panel hidden role="dialog" aria-modal="false"
  aria-labelledby="hm-detail-panel-title">
  <header class="hm-detail-panel-header">
    <h3 class="hm-detail-panel-title" id="hm-detail-panel-title" data-detail-title></h3>
    <button type="button" class="hm-detail-panel-close" data-detail-close
      aria-label="{{localize 'HEROMANCER.App.Equipment.DetailClose'}}">
      <i class="fas fa-xmark" aria-hidden="true"></i>
    </button>
  </header>
  <div class="hm-detail-panel-search">
    <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
    <input type="search" class="hm-detail-panel-search-input" data-detail-search autocomplete="off" spellcheck="false"
      aria-label="{{localize 'HEROMANCER.App.Equipment.DetailSearchLabel'}}">
  </div>
  <ul class="hm-detail-panel-list" data-detail-list role="listbox"></ul>
  <p class="hm-detail-panel-empty" data-detail-empty hidden>{{localize 'HEROMANCER.App.Equipment.DetailEmpty'}}</p>
</aside>
