{{!-- Hero Mancer Application Footer with Action Buttons --}}
<footer>
  <div class='hm-footer-container'>
    {{!-- Left div for Previous Button --}}
    <div class='hm-footer-left'>
      {{#if navigationButtons}}
        {{#unless isFirstTab}}
          <button type='button' data-action='previousTab' class='hm-app-nav-previous'
            data-tooltip='{{localize "hm.app.nav.previous"}}' aria-label='{{localize "hm.app.nav.previous"}}'>
            <i class="fas fa-chevron-left nav-prev" aria-hidden="true"></i>
            <span>{{localize "hm.app.nav.previous-format" tabName=previousTabName}}</span>
          </button>
        {{/unless}}
      {{/if}}
    </div>

    {{!-- Middle div for Action Buttons --}}
    <div class='hm-footer-middle'>
      <div class='hm-app-footer-actions'>
        {{!-- Randomize Button (conditional) --}}
        {{#if randomizeButton}}
          <button type='button' data-action='randomize' class='hm-app-footer-randomize'
            data-tooltip='{{localize "hm.app.randomize.randomize-character"}}'
            aria-label='{{localize "hm.app.randomize.randomize-character"}}'>
            <span>{{localize 'hm.app.randomize.randomize'}}</span>
          </button>
        {{/if}}

        {{!-- Save Options Button --}}
        <button type='submit' data-action='saveOptions' class='hm-app-footer-save'
          data-tooltip='{{localize "hm.app.save-description"}}' aria-label='{{localize "hm.app.save"}}'>
          <span>{{localize 'hm.app.save'}}</span>
        </button>

        {{!-- Reset Options Button --}}
        <button type='button' data-action='resetOptions' class='hm-app-footer-reset'
          data-tooltip='{{localize "hm.app.reset-description"}}' aria-label='{{localize "hm.app.reset"}}'>
          <span>{{localize 'hm.app.reset'}}</span>
        </button>

        {{!-- Cancel Button --}}
        <button type='button' data-action='nosubmit' class='hm-app-footer-cancel'
          data-tooltip='{{localize "hm.app.cancel-description"}}' aria-label='{{localize "hm.app.cancel"}}'>
          <span>{{localize 'hm.app.cancel'}}</span>
        </button>
      </div>
    </div>

    {{!-- Right div for Next/Submit Button --}}
    <div class='hm-footer-right'>
      {{#if isLastTab}}
        {{!-- Submit Button (on last tab) - text changes based on permission --}}
        {{#if canCreateActor}}
          <button type='submit' data-action="submit" class='hm-app-footer-submit'
            data-tooltip='{{localize "hm.app.submit-description"}}' aria-label='{{localize "hm.app.submit"}}'>
            <span>{{localize 'hm.app.submit'}}</span>
          </button>
        {{else}}
          <button type='submit' data-action="submit" class='hm-app-footer-submit hm-submit-approval'
            data-tooltip='{{localize "hm.approval.submit-description"}}'
            aria-label='{{localize "hm.approval.submit-for-approval"}}'>
            <span>{{localize 'hm.approval.submit-for-approval'}}</span>
          </button>
        {{/if}}
      {{else if navigationButtons}}
        {{!-- Next Button --}}
        <button type='button' data-action='nextTab' class='hm-app-nav-next' {{#if nextDisabled}}disabled
          aria-disabled="true" {{/if}} data-tooltip='{{localize "hm.app.nav.next"}}'
          aria-label='{{localize "hm.app.nav.next"}}'>
          <span>{{localize "hm.app.nav.next-format" tabName=nextTabName}}</span> <i
            class="fas fa-chevron-right nav-next" aria-hidden="true"></i>
        </button>
      {{/if}}
    </div>
  </div>
</footer>
