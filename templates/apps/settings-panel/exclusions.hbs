<section class="tab hm-dialog-tab standard-form {{#if tabs.exclusions.active}}active{{/if}}" data-group="primary"
  data-tab="exclusions">
  {{#each exclusions.groups}}
    {{#if this.label}}
      <h3 class="hm-sp-group-title">{{localize this.label}}</h3>
    {{/if}}
    {{#each this.settings}}{{> hmSettingsPanelField}}{{/each}}
  {{/each}}
</section>
